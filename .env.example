# ============================================================
#  错题银行 (WrongAnswerBank) — 环境变量样本
#  使用方式：cp .env.example .env  并填入真实值
# ============================================================

# === 运行环境 ===
ENV=dev

# === PostgreSQL ===
POSTGRES_USER=wab
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=wab
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === MinIO (对象存储) ===
MINIO_ROOT_USER=wabadmin
MINIO_ROOT_PASSWORD=change-me-min-32-chars-recommended
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=https://wab.ybgames.cn/files
MINIO_USE_SSL=false
MINIO_BUCKET_UPLOADS=wab-uploads
MINIO_BUCKET_TTS=wab-tts
MINIO_BUCKET_PDFS=wab-pdfs

# === FastAPI ===
API_SECRET_KEY=replace-with-32-or-more-random-chars
API_JWT_ALGORITHM=HS256
API_JWT_EXPIRE_MINUTES=10080
API_CORS_ORIGINS=https://wab.ybgames.cn,http://localhost:3000

# === LLM: DeepSeek 主力 ===
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_TEXT=deepseek-chat
DEEPSEEK_MODEL_VISION=deepseek-vl2

# === LLM: Qwen-VL 视觉兜底（可选） ===
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_VISION=qwen-vl-max

# === TTS ===
TTS_DEFAULT_VOICE=zh-CN-YunxiaNeural
TTS_DEFAULT_RATE=-10%

# === Next.js (Web) ===
NEXT_PUBLIC_API_BASE_URL=https://wab.ybgames.cn/api
NEXTAUTH_URL=https://wab.ybgames.cn
NEXTAUTH_SECRET=replace-with-32-or-more-random-chars
